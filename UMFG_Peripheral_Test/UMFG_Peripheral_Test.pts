         DL.AddComment vbCrLf & "--- 90-13_LCD_All pixels on"
         DL.SendSequence "90-13_LCD_All pixels on"
         result = DL.WaitForSequence("90 0x00", 1, 3000)
      end if
   
      if result <> 0 Then 
         check = msgbox("Do you see the LCD pixel all on?", vbyesno)
         if check = 6 then result = 1
         if check = 7 then result = 0
      end if
   end if 

   if j = 2 then
      If result <> 0 Then
         DL.AddComment vbCrLf & "--- 90-13_LCD_All pixels off"
         DL.SendSequence "90-13_LCD_All pixels off"
         result = DL.WaitForSequence("90 0x00", 1, 3000)
