         DL.SendSequence "90-13_All peripherals_All pixels and leds off"
         result = DL.WaitForSequence("90 0x00", 1, 3000)
       end if
   
      if result <> 0 Then 
         check = msgbox("Do you see All peripherals_All pixels and leds off?", vbyesno)
         if check = 6 then result = 1
         if check = 7 then result = 0
      end if
   end if
   next
end if
 
next
'------------------------------------------------------------ 

DL.AddComment vbCrLf
PrintMyResult(result)

DL.AddComment "---------- END OF TEST ----------" & vbCrLf
Else '""
  DL.AddComment vbCrLf & authnMsg & vbCrLf
End If '""

